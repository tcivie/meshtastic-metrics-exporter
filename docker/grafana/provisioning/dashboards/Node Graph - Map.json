                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          },
          "table": "node_details"
        },
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PA942B37CCFAF5A81"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "WITH pairs AS (\n    SELECT\n        source_id,\n        destination_id,\n        COUNT(*) AS pkts,\n        AVG(rx_snr)  AS avg_snr,\n        AVG(rx_rssi) AS avg_rssi\n    FROM mesh_packet_metrics\n    WHERE time > NOW() - INTERVAL '1 hour'\n      AND destination_id NOT IN ('4294967295','1','0')\n      AND source_id <> destination_id\n    GROUP BY source_id, destination_id\n)\nSELECT\n    source_id || '_' || destination_id AS id,\n    source_id      AS \"source\",\n    destination_id AS \"target\",\n    ROUND(avg_snr::numeric, 1) AS \"mainstat\",\n    pkts                      AS \"secondarystat\",\n    CASE\n        WHEN avg_snr < -13 THEN '#E74C3C'\n        WHEN avg_snr <  -7 THEN '#F4D03F'\n        ELSE '#2ECC71'\n    END AS \"color\",\n    GREATEST(0.5, LEAST(4, LOG(pkts + 1))) AS \"thickness\"\nFROM pairs\n\nUNION ALL\n\nSELECT\n    neighbor_id || '_' || node_id AS id,\n    neighbor_id AS \"source\",\n    node_id     AS \"target\",\n    snr         AS \"mainstat\",\n    NULL        AS \"secondarystat\",\n    CASE\n        WHEN snr < -13 THEN '#E74C3C'\n        WHEN snr <  -7 THEN '#F4D03F'\n        ELSE '#2ECC71'\n    END AS \"color\",\n    GREATEST(0.5, LEAST(4, 1 + ((snr + 13) / 10))) AS \"thickness\"\nFROM node_neighbors",
          "refId": "edges",
          "sql": {
            "columns": [
              {
                "parameters": [
                  {
                    "name": "id",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              },
              {
                "alias": "\"source\"",
                "parameters": [
                  {
                    "name": "neighbor_id",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              },
              {
                "alias": "\"target\"",
                "parameters": [
                  {
                    "name": "node_id",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              },
              {
                "alias": "\"mainstat\"",
                "parameters": [
                  {
                    "name": "snr",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          },
          "table": "node_neighbors"
        }
