      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PA942B37CCFAF5A81"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH pairs AS (\n    SELECT source_id, destination_id\n    FROM mesh_packet_metrics\n    WHERE time > NOW() - INTERVAL '1 hour'\n      AND destination_id NOT IN ('4294967295','1','0')\n      AND source_id <> destination_id\n),\nconnected AS (\n    SELECT source_id      AS node_id FROM pairs\n    UNION SELECT destination_id FROM pairs\n    UNION SELECT node_id        FROM node_neighbors\n    UNION SELECT neighbor_id    FROM node_neighbors\n),\nranked AS (\n    SELECT c.node_id, COUNT(p.*) AS conns\n    FROM connected c\n    LEFT JOIN pairs p\n      ON p.source_id = c.node_id OR p.destination_id = c.node_id\n    GROUP BY c.node_id\n    ORDER BY conns DESC\n    LIMIT 200\n)\nSELECT\n    cd.node_id AS \"id\",\n    cd.long_name AS \"title\",\n    cd.short_name AS \"subtitle\",\n    cd.hardware_model AS \"detail__Hardware Detail\",\n    cd.role AS \"detail__Client Role\",\n    cd.mqtt_status AS \"detail__MQTT Status\",\n    cd.longitude * 1e-7 AS \"longitude\",\n    cd.latitude  * 1e-7 AS \"latitude\",\n    CASE\n        WHEN cd.mqtt_status = 'online' THEN '#2ECC71'\n        WHEN cd.mqtt_status = 'offline' THEN '#E74C3C'\n        ELSE '#808080'\n    END AS \"color\"\nFROM node_details cd\nJOIN ranked r ON r.node_id = cd.node_id",
          "refId": "nodes",
          "sql": {
            "columns": [
              {
                "alias": "\"id\"",
                "parameters": [
                  {
                    "name": "node_id",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              },
              {
                "alias": "\"title\"",
                "parameters": [
                  {
                    "name": "long_name",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              },
              {
                "alias": "\"detail__Hardware Detail\"",
                "parameters": [
                  {
                    "name": "hardware_model",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              },
              {
                "alias": "\"detail__Client Role\"",
                "parameters": [
                  {
                    "name": "role",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              },
              {
                "alias": "\"detail__MQTT Status\"",
                "parameters": [
                  {
                    "name": "mqtt_status",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              },
              {
                "alias": "\"subtitle\"",
                "parameters": [
                  {
                    "name": "short_name",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
