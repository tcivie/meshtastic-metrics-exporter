      "id": 2,
      "type": "timeseries",
      "title": "Packets per minute by portnum",
      "description": "Per-portnum packet rate. Sustained spikes can indicate a misbehaving node or a routing storm.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PA942B37CCFAF5A81"
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
