          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT source_id) AS value FROM mesh_packet_metrics WHERE time > NOW() - INTERVAL '30 minutes'",
