          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT (100.0 * COUNT(*) FILTER (WHERE long_name IS NOT NULL   AND long_name <> 'Unknown')) / NULLIF(COUNT(*), 0) AS value FROM node_details WHERE node_id NOT IN ('4294967295','1','0')",
