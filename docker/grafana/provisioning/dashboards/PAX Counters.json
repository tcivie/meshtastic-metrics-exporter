    {
      "id": 2,
      "type": "stat",
      "title": "WiFi devices (latest)",
      "description": "Sum of latest WiFi station counts across PAX nodes.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PA942B37CCFAF5A81"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PA942B37CCFAF5A81"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(latest), 0)::float AS value FROM (  SELECT DISTINCT ON (node_id) node_id, wifi_stations AS latest   FROM pax_counter_metrics WHERE $__timeFilter(time)   ORDER BY node_id, time DESC) t",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
