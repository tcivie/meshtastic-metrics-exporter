    {
      "id": 1,
      "type": "stat",
      "title": "PAX nodes seen",
      "description": "Distinct PAX nodes in the time range.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PA942B37CCFAF5A81"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PA942B37CCFAF5A81"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(DISTINCT node_id)::float AS value FROM pax_counter_metrics WHERE $__timeFilter(time)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
