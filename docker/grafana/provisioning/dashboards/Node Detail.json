    {
      "id": 1,
      "type": "table",
      "title": "Node",
      "description": "Latest known state for the selected node.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PA942B37CCFAF5A81"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PA942B37CCFAF5A81"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT node_id, short_name, long_name, hardware_model, role, mqtt_status,        latitude  * 1e-7 AS latitude,        longitude * 1e-7 AS longitude, altitude, updated_at FROM node_details WHERE node_id = '$nodeID' LIMIT 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true,
            "inspect": false
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      }
    },
    {
      "id": 30,
      "type": "geomap",
      "title": "Location",
      "description": "Last-known position for this node. Empty if the node hasn't broadcast a Position or MapReport.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PA942B37CCFAF5A81"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PA942B37CCFAF5A81"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT node_id,        COALESCE(NULLIF(long_name,'Unknown'), short_name, node_id) AS name,        hardware_model, role,        longitude * 1e-7 AS longitude_norm,        latitude  * 1e-7 AS latitude_norm, altitude FROM node_details WHERE node_id = '$nodeID' AND longitude IS NOT NULL AND longitude <> 0",
          "refId": "Nodes"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "basemap": {
          "config": {},
          "name": "Basemap",
          "type": "default"
        },
        "controls": {
          "mouseWheelZoom": true,
          "showAttribution": true,
          "showDebug": false,
          "showMeasure": false,
          "showScale": true,
          "showZoom": true
        },
        "layers": [
          {
            "name": "Node",
            "type": "markers",
            "config": {
              "showLegend": false,
              "style": {
                "color": {
                  "fixed": "red"
                },
                "opacity": 1,
                "size": {
                  "fixed": 10
                },
                "symbol": {
                  "fixed": "img/icons/marker/circle.svg",
                  "mode": "fixed"
                }
              }
            },
            "filterData": {
              "id": "byRefId",
              "options": "Nodes"
            },
            "location": {
              "latitude": "latitude_norm",
              "longitude": "longitude_norm",
              "mode": "coords"
            },
            "tooltip": true
          }
        ],
        "tooltip": {
          "mode": "details"
        },
        "view": {
          "id": "fit",
          "allLayers": true,
          "lastOnly": false,
          "padding": 30
        }
